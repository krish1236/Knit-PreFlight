# Anthropic API key — Tier 4 account required for production demo throughput
ANTHROPIC_API_KEY=sk-ant-...

# Postgres
DATABASE_URL=postgresql+asyncpg://preflight:preflight@localhost:5432/preflight

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Cost guardrails
MAX_DAILY_SPEND_USD=20
MAX_RUNS_PER_IP_PER_HOUR=5
